{
  "name": "staff-app",
  "private": true,
  "version": "1.2.1",
  "description": "Oxton Oportal",
  "author": "Oxton",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite\" \"cross-env ELECTRON_START_URL=http://localhost:5173 wait-on tcp:5173 && electron .\"",
    "build": "vite build",
    "build:app": "vite build && electron-builder --win",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "firebase": "^12.15.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.18.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-easy-crop": "^6.0.2",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "wait-on": "^9.0.10"
  },
  "allowScripts": {
    "puppeteer@25.2.1": true
  },
  "build": {
    "appId": "com.oxton.oportal",
    "productName": "Oxton Oportal",
    "publish": {
      "provider": "github",
      "owner": "evanm100000-maker",
      "repo": "Oxton-Oportal"
    },
    "directories": {
      "output": "dist_electron"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "uninstallDisplayName": "Oxton Oportal"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ]
  }
}
